# Copy this file to .env and fill in values
# .env is gitignored — never commit secrets

# App
APP_ENV=development
SECRET_KEY=changeme-use-openssl-rand-hex-32

# Database (add when needed)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# CORS — comma-separated origins allowed to call the backend
CORS_ORIGINS=http://localhost:5173

# Frontend (adapter-node)
# ORIGIN is required in production to prevent CSRF (set to the public URL of the frontend)
# ORIGIN=https://myapp.example.com
# PORT=3000

# Frontend — public env vars must be prefixed PUBLIC_
# PUBLIC_API_BASE_URL=http://localhost:8000
