# Copy this file to .env and fill in values.
# .env is gitignored — never commit secrets.

# --- Backend ---
DATABASE_URL=postgresql+asyncpg://idealens:idealens@localhost:5432/idealens
JWT_SECRET=change-me-generate-with-secrets-token-hex-64
JWT_ALGORITHM=HS256
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=
# Dev: comma-separated; prod: your domain only
FRONTEND_URLS_RAW=http://localhost:5173
ENVIRONMENT=development
TEST_DATABASE_URL=postgresql+asyncpg://idealens:idealens@localhost:5432/idealens_test
# Optional — seeds a default Anthropic API key for local dev
SEED_ANTHROPIC_API_KEY=

# --- Frontend ---
# Public vars live in frontend/.env.development and frontend/.env.production.
# Vite requires env files alongside vite.config.ts — they cannot be moved.
# frontend/.env.development:  PUBLIC_API_URL=http://localhost:8000
# frontend/.env.production:   PUBLIC_API_URL=<deployed backend URL>

# --- AWS Deploy ---
# Used by deploy/aws/setup-infra.sh and deploy/aws/deploy.sh.
# Leave blank when not deploying to AWS.
APP_NAME=
AWS_REGION=us-east-1
APPRUNNER_ECR_ROLE_ARN=
# Master password for the RDS instance — only needed by setup-infra.sh.
# After setup, DATABASE_URL above already contains it.
DB_PASSWORD=
# Output of setup-infra.sh — leave blank until after first infra setup.
VPC_CONNECTOR_ARN=
